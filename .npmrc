# Prevent automatic execution of install scripts from dependencies
# Reduces risk of malicious lifecycle scripts
ignore-scripts=true

# Enforce strict peer dependency validation
strict-peer-deps=true

# Enable vulnerability auditing
audit=true

# Disable funding messages
fund=false

# Use the official npm registry over HTTPS
registry=https://registry.npmjs.org/

# Improve pnpm compatibility and dependency resolution
auto-install-peers=true

# Avoid unexpected workspace linking behavior in the future
prefer-workspace-packages=false
