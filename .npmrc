# Prevent automatic execution of install scripts (e.g., postinstall)
# Reduces risk of malicious code in dependencies
ignore-scripts=true

# Enforce strict resolution of peer dependencies
# Fails installation if peer dependency requirements are not met
strict-peer-deps=true

# Enable security audit on install
# Helps detect known vulnerabilities early
audit=true

# Disable funding messages to keep output clean
fund=false

# Ensure packages are always fetched over HTTPS
registry=https://registry.npmjs.org/

# Skip optional dependencies
# Reduces install size and potential attack surface
optional=false
