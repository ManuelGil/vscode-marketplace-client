{
	"name": "vscode-marketplace-client",
	"description": "A TypeScript library for fetching and managing Visual Studio Code extensions, with version querying, VSIX downloads, and robust error handling.",
	"version": "1.2.3",
	"license": "MIT",
	"author": "ManuelGil",
	"homepage": "https://github.com/ManuelGil/vscode-marketplace-client",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/vscode-marketplace-client.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/vscode-marketplace-client/issues"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"node": ">=18.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"vscode",
		"visual-studio-code",
		"marketplace",
		"marketplace-api",
		"extensions",
		"extensions-api",
		"client",
		"typescript",
		"node",
		"vsix",
		"open-vsx"
	],
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.ts"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"clean": "rimraf dist",
		"build": "tsup",
		"pretest": "pnpm run clean && pnpm run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"format": "prettier --write .",
		"check-format": "prettier --check .",
		"lint": "eslint . --ext .ts",
		"lint:fix": "eslint . --ext .ts --fix",
		"ts-check": "tsc --noEmit",
		"check-exports": "attw --pack .",
		"pack:check": "pnpm pack",
		"audit": "pnpm audit",
		"link": "cd dist && pnpm link",
		"publish:verdaccio": "pnpm publish --registry http://localhost:4873",
		"prepare": "husky",
		"release": "release-it"
	},
	"dependencies": {
		"axios": "1.16.1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@eslint/js": "^9.39.4",
		"@types/node": "^20.19.41",
		"eslint": "^9.39.4",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"prettier": "^3.8.3",
		"release-it": "^20.0.1",
		"rimraf": "^6.1.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.3",
		"vitest": "^3.2.4"
	},
	"lint-staged": {
		"*.ts": [
			"eslint --fix",
			"prettier --write"
		]
	},
	"release-it": {
		"git": {
			"commitMessage": "chore: :bookmark: release ${version}",
			"tagName": "v${version}"
		},
		"github": {
			"release": true
		},
		"npm": {
			"publish": false
		},
		"hooks": {
			"before:init": "pnpm test",
			"before:release": "pnpm build"
		}
	},
	"pnpm": {
		"overrides": {
			"@conventional-changelog/git-client@<2.0.0": ">=2.0.0",
			"fast-uri@<=3.1.1": ">=3.1.2"
		}
	}
}
