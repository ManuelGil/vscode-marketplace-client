{
	"name": "vscode-marketplace-client",
	"description": "A TypeScript library for fetching and managing Visual Studio Code extensions, with version querying, VSIX downloads, and robust error handling.",
	"version": "1.1.1",
	"license": "MIT",
	"author": "ManuelGil",
	"sponsor": {
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"engines": {
		"node": ">=18.0.0",
		"npm": ">=9.0.0"
	},
	"keywords": [
		"vscode",
		"marketplace",
		"extensions",
		"client",
		"typescript",
		"node"
	],
	"homepage": "https://github.com/ManuelGil/vscode-marketplace-client",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/vscode-marketplace-client.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/vscode-marketplace-client/issues"
	},
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "rimraf dist",
		"build": "tsup",
		"pretest": "npm run clean && npm run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"format": "prettier --write .",
		"lint": "eslint . --ext .ts",
		"ts-check": "tsc --noEmit",
		"check-format": "prettier --check .",
		"check-exports": "attw --pack .",
		"link": "cd dist && npm link",
		"publish:verdaccio": "npm publish --registry http://localhost:4873",
		"publish": "npm publish --access=public",
		"prepare": "husky",
		"release": "release-it"
	},
	"dependencies": {
		"axios": "1.15.1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^9.39.4",
		"@types/axios": "^0.14.4",
		"@types/node": "^20.19.39",
		"eslint": "^9.39.4",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"prettier": "^3.8.3",
		"release-it": "^20.0.0",
		"rimraf": "^6.1.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.2",
		"vitest": "^3.2.4"
	},
	"lint-staged": {
		"*.ts": [
			"eslint --fix",
			"prettier --write"
		]
	},
	"release-it": {
		"git": {
			"commitMessage": "chore: :bookmark: release ${version}"
		},
		"github": {
			"release": true
		},
		"npm": {
			"publish": false
		}
	}
}
