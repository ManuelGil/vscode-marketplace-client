{
	"compilerOptions": {
		"target": "ESNext",
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"types": [
			"node"
		],
		"strict": true,
		"declaration": true,
		"rootDir": "./src",
		"declarationDir": "./dist",
		"outDir": "./dist",
		"stripInternal": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"emitDecoratorMetadata": false
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
